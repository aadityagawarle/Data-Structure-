#include <stdio.h>
#include <string.h>

int isBalanced(char* s) {
    int n = strlen(s);
    char stack[100000];
    int top = -1;

    for (int i = 0; i < n; i++) {
        char ch = s[i];

        if (ch == '(' || ch == '{' || ch == '[') {
            stack[++top] = ch;
        } else {
            if (top == -1)
                return 0;

            char last = stack[top];

            if ((ch == ')' && last == '(') ||
                (ch == '}' && last == '{') ||
                (ch == ']' && last == '[')) {
                top--;
            } else {
                return 0;
            }
        }
    }

    return top == -1;
}

int main() {
    char s1[] = "[{()}]";
    char s2[] = "[()(){]{}";
    char s3[] = "([]";
    char s4[] = "{[{}]}";

    printf("Input: %s => %s\n", s1, isBalanced(s1) ? "true" : "false");
    printf("Input: %s => %s\n", s2, isBalanced(s2) ? "true" : "false");
    printf("Input: %s => %s\n", s3, isBalanced(s3) ? "true" : "false");
    printf("Input: %s => %s\n", s4, isBalanced(s4) ? "true" : "false");

    return 0;
}
